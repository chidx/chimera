# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chimera

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Pinata (IPFS)
PINATA_JWT=
PINATA_GATEWAY=

# Blockchain signing
DEPLOYER_PRIVATE_KEY=0x
DEPLOYER_ADDRESS=0x

# Monad RPC
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Agent mode
AGENT_MODE=e2b
#AGENT_MODE=local

# E2B sandbox
E2B_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Ably (real-time messaging)
ABLY_API_KEY=

# Internal service URL (used by worker to call back the API)
BACKEND_URL=http://localhost:3000

# USDC token address on Monad Testnet
USDC_ADDRESS=0x534b2f3A21130d7a60830c2Df862319e593943A3

