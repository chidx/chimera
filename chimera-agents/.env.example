# Backend API (agent_runner.py calls this to resolve identity + mission context)
BACKEND_URL=http://localhost:3000

# PostgreSQL (agent_worker.py persists job results here)
DATABASE_URL=postgresql://chimera:chimera@localhost:5432/chimera

# Redis (BullMQ queue — bull:agent-tasks:wait)
REDIS_URL=redis://localhost:6379

# OpenAI (agent_runner.py — passed into E2B sandbox when running in E2B mode)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
